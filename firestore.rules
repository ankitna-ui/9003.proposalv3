rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Proposal Security Rules
    match /proposals/{proposalId} {
      // Allow creation if the user is authenticated
      allow create: if request.auth != null;
      
      // BOLA Protection: Allow read/update/delete only if the user owns the document
      // We check if the 'userId' field in the document matches the authenticated user's UID
      allow read, update, delete: if request.auth != null && 
        (resource.data.userId == request.auth.uid || proposalId == 'sample-1' || proposalId == 'sample-2');
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
